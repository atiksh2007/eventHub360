datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. QUOTATION TABLE
// ==========================================
model Quotation {
  quotation_id   BigInt     @id @default(autoincrement())
  company_id     BigInt
  lead_id        BigInt
  version        Int        @default(1)
  currency       String     @db.Char(3) @default("USD")
  
  subtotal       Decimal    @db.Decimal(14, 2)
  tax_total      Decimal    @db.Decimal(14, 2)
  total          Decimal    @db.Decimal(14, 2)
  cost_total     Decimal    @db.Decimal(14, 2)
  margin         Decimal    @db.Decimal(14, 2)
  
  status         String     @db.VarChar(15)    // Draft/Sent/Accepted/Expired
  expires_at     DateTime   @db.Date

  // Implicit Multi-tenant Columns
  tenant_id      String     @db.VarChar(50)
  branch_id      BigInt?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  created_by     BigInt?
  updated_by     BigInt?
  is_active      Boolean    @default(true)

  // Relations
  lines          QuotationLine[]
  approvals      QuoteApproval[]

  @@unique([quotation_id, version])
  @@map("quotation")
}

// ==========================================
// 2. QUOTATION LINE TABLE
// ==========================================
model QuotationLine {
  line_id        BigInt     @id @default(autoincrement())
  quotation_id   BigInt
  item_type      String     @db.VarChar(20)    // Venue/Package/Vendor/Service
  ref_id         BigInt?                       
  description    String     @db.VarChar(200)
  
  qty            Decimal    @db.Decimal(10, 2)
  rate           Decimal    @db.Decimal(14, 2) 
  cost           Decimal    @db.Decimal(14, 2) 
  amount         Decimal    @db.Decimal(14, 2) 
  tax_rule_id    BigInt

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  is_active      Boolean    @default(true)

  // Relations
  quotation      Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("quotation_line")
}

// ==========================================
// 3. QUOTE APPROVAL TABLE
// ==========================================
model QuoteApproval {
  approval_id    BigInt     @id @default(autoincrement())
  quotation_id   BigInt
  approver_id    BigInt?                       
  status         String     @db.VarChar(15)    // pending/approved/rejected
  decided_at     DateTime?  @db.Timestamptz

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  created_at     DateTime   @default(now())

  // Relations
  quotation      Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("quote_approval")
}

// ==========================================
// 4. PRICE BOOK & RATE CARD CATALOG TABLES
// ==========================================
model PriceBook {
  price_book_id  BigInt     @id @default(autoincrement())
  company_id     BigInt
  name           String     @db.VarChar(60)    
  valid_from     DateTime   @db.Date
  valid_to       DateTime   @db.Date

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  is_active      Boolean    @default(true)

  rates          RateCard[]

  @@map("price_book")
}

model RateCard {
  rate_card_id   BigInt     @id @default(autoincrement())
  price_book_id  BigInt
  item_name      String     @db.VarChar(120)   
  uom            String     @db.VarChar(15)    
  rate           Decimal    @db.Decimal(14, 2) 
  cost           Decimal    @db.Decimal(14, 2) 

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)

  priceBook      PriceBook  @relation(fields: [price_book_id], references: [price_book_id], onDelete: Cascade)

  @@map("rate_card")
}