datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. QUOTATION TABLE
// ==========================================
model Quotation {
  quotation_id   BigInt     @id @default(autoincrement())
  company_id     BigInt
  lead_id        BigInt
  version        Int        @default(1)
  currency       String     @db.Char(3) @default("USD")
  
  title          String?    @db.VarChar(100)
  client_tier    String?    @db.VarChar(50)
  event_date     String?    @db.VarChar(50)
  expected_guests String?   @db.VarChar(50)
  discount_global Decimal   @db.Decimal(14, 2) @default(0)
  charge_service  Decimal   @db.Decimal(14, 2) @default(0)

  subtotal       Decimal    @db.Decimal(14, 2)
  tax_total      Decimal    @db.Decimal(14, 2)
  total          Decimal    @db.Decimal(14, 2)
  cost_total     Decimal    @db.Decimal(14, 2)
  margin         Decimal    @db.Decimal(14, 2)
  
  status         String     @db.VarChar(20)    // Draft/Sent/Accepted/Expired/PENDING_APPROVAL
  expires_at     DateTime   @db.Date
  metadata       Json?

  // Implicit Multi-tenant Columns
  tenant_id      String     @db.VarChar(50)
  branch_id      BigInt?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  created_by     BigInt?
  updated_by     BigInt?
  is_active      Boolean    @default(true)

  // Relations
  lines          QuotationLine[]
  approvals      QuoteApproval[]
  proposals      ProposalDocument[]
  comments       QuotationComment[]

  @@unique([quotation_id, version])
  @@map("quotation")
}

// ==========================================
// 2. QUOTATION LINE TABLE
// ==========================================
model QuotationLine {
  line_id        BigInt     @id @default(autoincrement())
  quotation_id   BigInt
  item_type      String     @db.VarChar(20)    // Venue/Package/Vendor/Service
  ref_id         BigInt?                       
  description    String     @db.VarChar(200)
  
  qty            Decimal    @db.Decimal(10, 2)
  rate           Decimal    @db.Decimal(14, 2) 
  cost           Decimal    @db.Decimal(14, 2) 
  amount         Decimal    @db.Decimal(14, 2) 
  tax_rule_id    BigInt

  markup_pct     Decimal    @db.Decimal(5, 2) @default(0)
  discount_pct   Decimal    @db.Decimal(5, 2) @default(0)
  tax_rate_pct   Decimal    @db.Decimal(5, 2) @default(18)
  cgst           Decimal    @db.Decimal(14, 2) @default(0)
  sgst           Decimal    @db.Decimal(14, 2) @default(0)
  igst           Decimal    @db.Decimal(14, 2) @default(0)

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  is_active      Boolean    @default(true)

  // Relations
  quotation      Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("quotation_line")
}

// ==========================================
// 3. QUOTE APPROVAL TABLE
// ==========================================
model QuoteApproval {
  approval_id    BigInt     @id @default(autoincrement())
  quotation_id   BigInt
  approver_id    BigInt?                       
  status         String     @db.VarChar(15)    // pending/approved/rejected
  decided_at     DateTime?  @db.Timestamptz

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  created_at     DateTime   @default(now())

  // Relations
  quotation      Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("quote_approval")
}

// ==========================================
// 4. PRICE BOOK & RATE CARD CATALOG TABLES
// ==========================================
model PriceBook {
  price_book_id  BigInt     @id @default(autoincrement())
  company_id     BigInt
  name           String     @db.VarChar(60)    
  valid_from     DateTime   @db.Date
  valid_to       DateTime   @db.Date

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  is_active      Boolean    @default(true)

  rates          RateCard[]

  @@map("price_book")
}

model RateCard {
  rate_card_id   BigInt     @id @default(autoincrement())
  price_book_id  BigInt
  item_name      String     @db.VarChar(120)   
  uom            String     @db.VarChar(15)    
  rate           Decimal    @db.Decimal(14, 2) 
  cost           Decimal    @db.Decimal(14, 2) 

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)

  priceBook      PriceBook  @relation(fields: [price_book_id], references: [price_book_id], onDelete: Cascade)

  @@map("rate_card")
}

// ==========================================
// 5. PACKAGE TABLE
// ==========================================
model Package {
  package_id     BigInt     @id @default(autoincrement())
  company_id     BigInt
  name           String     @db.VarChar(120)
  base_price     Decimal    @db.Decimal(14, 2)

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  is_active      Boolean    @default(true)

  @@map("package")
}

// ==========================================
// 6. PROPOSAL DOCUMENTS TABLE
// ==========================================
model ProposalDocument {
  doc_id         BigInt     @id @default(autoincrement())
  quotation_id   BigInt
  blob_url       String     @db.Text
  public_hash    String     @unique @db.VarChar(64)

  // Implicit Tenant Columns
  tenant_id      String     @db.VarChar(50)
  created_at     DateTime   @default(now())

  // Relations
  quotation      Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("proposal_documents")
}

// ==========================================
// 6. NOTIFICATION TABLE
// ==========================================
model Notification {
  notification_id BigInt     @id @default(autoincrement())
  user_id         BigInt
  title           String     @db.VarChar(120)
  description     String     @db.Text
  type            String     @db.VarChar(50)    // approval, mention, system
  reference_id    BigInt?                       // e.g., quotation_id
  is_read         Boolean    @default(false)
  
  // Implicit Tenant Columns
  tenant_id       String     @db.VarChar(50)
  created_at      DateTime   @default(now())

  @@map("notification")
}

// ==========================================
// 7. QUOTATION COMMENT TABLE (DISCUSSION)
// ==========================================
model QuotationComment {
  comment_id      BigInt     @id @default(autoincrement())
  quotation_id    BigInt
  user_id         BigInt?    // Nullable because it could be a client
  client_email    String?    @db.VarChar(255) // Stores verified client email
  content         String     @db.Text
  is_private      Boolean    @default(true)   // True = Internal only
  
  // Implicit Tenant Columns
  tenant_id       String     @db.VarChar(50)
  created_at      DateTime   @default(now())

  // Relations
  quotation       Quotation  @relation(fields: [quotation_id], references: [quotation_id], onDelete: Cascade)

  @@map("quotation_comment")
}